---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  // Get all unique categories
  const categories = [...new Set(allPosts.flatMap(post => post.data.categories))];
  
  // For each category, filter posts that include that category
  return categories.map(category => {
    const filteredPosts = allPosts.filter(post => 
      post.data.categories.includes(category)
    );
    
    return {
      params: { category: category.toLowerCase().replace(/\s+/g, '-') },
      props: { 
        category, 
        posts: filteredPosts 
      }
    };
  });
}

interface Props {
  category: string;
  posts: CollectionEntry<'blog'>[];
}

const { category, posts } = Astro.props;

// Sort posts by date in descending order (newest first)
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Format for display
const formattedPosts = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  date: post.data.date,
  slug: post.slug,
  categories: post.data.categories
}));
---

<Layout 
  title={`${category} | Blog | Yusril Izza Aulia`}
  description={`Articles about ${category} - web development, design, and technology insights.`}
>
  <Navbar />
  
  <main class="flex-1">
    <section class="py-24 md:py-32">
      <div class="container-custom">
        <div class="mb-12">
          <a href="/blog" class="group inline-flex items-center gap-2 text-sm font-medium text-neutral-500 hover:text-foreground transition-colors mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            All posts
          </a>
          
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
            <span class="text-neutral-400 dark:text-neutral-600">Category:</span> {category}
          </h1>
          <p class="text-neutral-500 mt-3">
            Showing {formattedPosts.length} post{formattedPosts.length !== 1 ? 's' : ''}
          </p>
        </div>
        
        <div class="space-y-12">
          {formattedPosts.map((post) => (
            <article class="group relative flex flex-col items-start justify-between">
              <div class="flex items-center gap-4 text-xs mb-4">
                <time datetime={post.date.toISOString()} class="text-neutral-500 font-medium">
                  {new Date(post.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>
                {post.categories.length > 0 && (
                  <div class="flex gap-2">
                    {post.categories.slice(0, 2).map((cat: string) => (
                      <span class="relative z-10 rounded-full bg-neutral-100 dark:bg-neutral-800 px-3 py-1 font-medium text-neutral-600 dark:text-neutral-300">{cat}</span>
                    ))}
                  </div>
                )}
              </div>
              
              <div class="group relative">
                <h2 class="mt-3 text-2xl font-bold tracking-tight text-foreground group-hover:text-primary transition-colors">
                  <a href={`/blog/${post.slug}`}>
                    <span class="absolute inset-0 z-20"></span>
                    {post.title}
                  </a>
                </h2>
                <p class="mt-4 text-neutral-600 dark:text-neutral-400 line-clamp-3 text-pretty leading-relaxed">{post.description}</p>
              </div>
              
              <div class="relative z-10 mt-6 flex items-center text-sm font-medium text-primary">
                Read article <span aria-hidden="true" class="ml-1 transition-transform group-hover:translate-x-1">&rarr;</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
