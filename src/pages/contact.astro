---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Mail from "@lucide/astro/icons/mail";
---

<Layout
  title="Contact | Yusril Izza Aulia"
  description="Get in touch with Yusril Izza Aulia for collaborations, questions, or just to say hello."
>
  <Navbar />

  <main class="flex-1">
    <section class="py-24 md:py-32">
      <div class="container-custom">
        <div class="max-w-2xl mb-16">
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">Get in Touch</h1>
          <p class="text-lg text-neutral-500 text-balance">
            Have a question, project idea, or just want to say hello? I'd love to
            hear from you. Feel free to reach out through any of the channels
            below.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div class="group relative overflow-hidden rounded-3xl border border-neutral-200/50 dark:border-neutral-800/50 bg-neutral-50/50 dark:bg-neutral-900/30 p-8 hover:shadow-lg transition-all duration-300">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 rounded-full bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center">
                <i class="text-lg devicon-telegram-original"></i>
              </div>
              <h2 class="text-lg font-bold tracking-tight">Telegram</h2>
            </div>
            <p class="text-sm text-neutral-500 mb-6">
              Chat with me directly on Telegram for a quick response.
            </p>
            <a
              href="https://t.me/izzadev"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-foreground text-background text-sm font-medium hover:scale-105 transition-transform"
            >
              Message on Telegram
            </a>
          </div>

          <div class="group relative overflow-hidden rounded-3xl border border-neutral-200/50 dark:border-neutral-800/50 bg-neutral-50/50 dark:bg-neutral-900/30 p-8 hover:shadow-lg transition-all duration-300">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 rounded-full bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"></path></svg>
              </div>
              <h2 class="text-lg font-bold tracking-tight">WhatsApp</h2>
            </div>
            <p class="text-sm text-neutral-500 mb-6">
              Send me a message on WhatsApp for project inquiries.
            </p>
            <a
              href="https://wa.me/6285172441406"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-foreground text-background text-sm font-medium hover:scale-105 transition-transform"
            >
              Chat on WhatsApp
            </a>
          </div>

          <div class="group relative overflow-hidden rounded-3xl border border-neutral-200/50 dark:border-neutral-800/50 bg-neutral-50/50 dark:bg-neutral-900/30 p-8 hover:shadow-lg transition-all duration-300 sm:col-span-2">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 rounded-full bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center">
                <Mail size={18} />
              </div>
              <h2 class="text-lg font-bold tracking-tight">Email</h2>
            </div>
            <p class="text-sm text-neutral-500 mb-6">
              For professional inquiries, feel free to send me an email.
            </p>
            <a
              href="mailto:yusril@izza.dev"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-foreground text-background text-sm font-medium hover:scale-105 transition-transform"
            >
              <Mail size={16} />
              Send Email
            </a>
          </div>
        </div>

        <div class="mt-16">
          <h2 class="text-lg font-bold tracking-tight mb-6">Connect with me</h2>
          <div class="flex items-center gap-3">
            <a href="https://github.com/underworld14" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-neutral-100 dark:bg-neutral-900 text-neutral-500 hover:text-foreground transition-colors">
              <span class="sr-only">GitHub</span>
              <i class="text-lg devicon-github-original"></i>
            </a>
            <a href="https://linkedin.com/in/izza-srv" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-neutral-100 dark:bg-neutral-900 text-neutral-500 hover:text-foreground transition-colors">
              <span class="sr-only">LinkedIn</span>
              <i class="text-lg devicon-linkedin-plain"></i>
            </a>
            <a href="mailto:yusril@izza.dev" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-neutral-100 dark:bg-neutral-900 text-neutral-500 hover:text-foreground transition-colors">
              <span class="sr-only">Email</span>
              <Mail size={18} />
            </a>
            <a href="https://x.com/underworld146" target="_blank" rel="noopener noreferrer" class="p-3 rounded-full bg-neutral-100 dark:bg-neutral-900 text-neutral-500 hover:text-foreground transition-colors">
              <span class="sr-only">Twitter</span>
              <i class="text-lg devicon-twitter-original"></i>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
