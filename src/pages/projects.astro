---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import { BorderBeam } from "@/components/magicui/border-beam";

import luminapdfImg from "@/assets/projects/luminapdf.png";
import utarakanImg from "@/assets/projects/utarakan.png";
import carecryptoImg from "@/assets/projects/carecrypto.png";
import sharekoreanImg from "@/assets/projects/sharekorean.png";
import adhyaksamartImg from "@/assets/projects/adhyaksamart.png";

const projects = [
  {
    title: "Utarakan.id",
    description:
      "Anonymous social platform for sharing thoughts and experiences. Personal project attracting 600+ registered users with integrated payment processing.",
    tags: ["SvelteKit", "Supabase", "TWA", "Mayar Payment"],
    link: "https://utarakan.id",
    image: utarakanImg,
  },
  {
    title: "Carecrypto",
    description:
      "Membership-based crypto community for Seoul residents with integrated payment system and multiple membership tiers.",
    tags: ["Next.js", "Express.js", "MongoDB", "AWS Amplify", "AWS Elastic Beanstalk"],
    link: "https://carecrypto.com",
    image: carecryptoImg,
  },
  {
    title: "Adhyaksamart Voucher",
    description:
      "Digital voucher management system for Adhyaksamart members in Yogyakarta; manages 1,000+ vouchers monthly.",
    tags: ["SvelteKit", "SQLite"],
    link: "https://adhyaksamart.my.id",
    image: adhyaksamartImg,
  },
  {
    title: "Sharekorean",
    description:
      "Community platform with job portal for Koreans in the United States, offering specialized employment opportunities.",
    tags: ["Next.js", "Express.js", "MongoDB", "DigitalOcean"],
    link: "https://sharekorean.com",
    image: sharekoreanImg,
  },
  {
    title: "Abqory Sharia",
    description:
      "Course and event management system for Sharia-based economic education, enabling structured learning and event registration.",
    tags: ["Next.js", "Strapi"],
    link: "https://abqorysharia.com",
    image: luminapdfImg,
  }
];
---

<Layout
  title="Projects | Yusril Izza Aulia"
  description="Explore a selection of my latest projects, showcasing fullstack web development and scalable architectures."
>
  <Navbar />

  <main class="flex-1">
    <section class="py-24 md:py-32">
      <div class="container-custom">
        <div class="max-w-2xl mb-16">
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">Works & Projects</h1>
          <p class="text-lg text-neutral-500 text-balance">
            A deep dive into the products and tools I've built. Focusing on performance, 
            beautiful user interfaces, and scalable backend architectures.
          </p>
        </div>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-2">
          {
            projects.map((project) => (
              <div class="group relative flex flex-col overflow-hidden rounded-[2rem] border border-neutral-200/60 bg-white/50 dark:border-neutral-800/60 dark:bg-neutral-900/50 backdrop-blur-sm transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
                <div class="relative w-full aspect-[16/10] overflow-hidden bg-neutral-100 dark:bg-neutral-800">
                  <Image
                    src={project.image}
                    alt={project.title}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                    <div class="w-full flex justify-end">
                      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/20 backdrop-blur-md text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="7" y1="17" x2="17" y2="7"></line>
                          <polyline points="7 7 17 7 17 17"></polyline>
                        </svg>
                      </span>
                    </div>
                  </div>
                </div>

                <div class="flex flex-col flex-1 p-8">
                  <h3 class="text-2xl font-bold tracking-tight mb-3 group-hover:text-primary transition-colors">{project.title}</h3>
                  <p class="text-neutral-500 dark:text-neutral-400 mb-8 flex-1 text-pretty leading-relaxed">
                    {project.description}
                  </p>

                  <div class="flex flex-wrap gap-2 mt-auto">
                    {project.tags.map((tag) => (
                      <span class="inline-flex items-center rounded-full bg-neutral-100 px-4 py-1.5 text-xs font-semibold text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <a
                  href={project.link}
                  class="absolute inset-0 z-10"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="sr-only">Visit {project.title}</span>
                </a>

                <BorderBeam client:idle duration={8} size={150} />
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
