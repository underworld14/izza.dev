---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Footer from '../components/Footer.astro';
---

<Layout
	title="Yusril Izza Aulia | Fullstack Engineer"
	description="Personal website of Muhamad Yusril Izza Aulia, showcasing fullstack engineering experience with React, Next.js, Remix, Svelte, Node.js, and Golang, along with projects and professional background."
>
	<Navbar />
	
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Person",
		"name": "Muhamad Yusril Izza Aulia",
		"jobTitle": "Fullstack Engineer",
		"url": "https://izza.dev",
		"sameAs": [
			"https://github.com/underworld14",
			"https://linkedin.com/in/izza-srv",
			"https://x.com/underworld146"
		],
		"worksFor": {
			"@type": "Organization",
			"name": "Ultravoucher"
		}
	})} />

	<main>
		<Hero />
		<Skills />
		<Experience />
		<Projects />
		<BlogPreview />
	</main>
	
	<Footer />
</Layout>
