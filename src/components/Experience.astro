---
const experiences = [
  {
    company: "Qonflo AI",
    position: "Fullstack Engineer",
    period: "Jul 2025 - Present",
    location: "Surabaya",
    achievements: [
      "Architected and developed a high-performance workflow orchestration engine handling complex customer business logic",
      "Led the Frontend V2 initiative, restructuring core codebase resulting in 40% faster rendering speeds",
      "Engineered a 'Datapoint' synchronization system managing customer data across multiple AI interactions with 99.9% data consistency",
      "Implemented real-time communication infrastructure supporting concurrent AI workflows",
    ],
  },
  {
    company: "Ultravoucher",
    position: "Frontend Engineer",
    period: "Oct 2023 - May 2025",
    location: "Jakarta",
    achievements: [
      "Optimized ultracorp.co.id for search, increasing organic traffic and brand visibility",
      "Led Frontend Development Team for the Central Reporting Platform serving enterprise clients",
      "Introduced Remix Framework best practices, establishing new frontend architecture standards",
      "Enhanced Ultravoucher.co.id web platform, expanding user reach across multiple channels",
    ],
  },
  {
    company: "PT. Software Service Indonesia",
    position: "React Developer",
    period: "Oct 2021 - Oct 2023",
    location: "Yogyakarta",
    achievements: [
      "Spearheaded maintenance and feature development for Agentpoint real estate platform",
      "Developed and optimized Property Listing Advertisement (PLA) view blocks, improving listing engagement",
      "Revamped Content+ Dashboard UI, enhancing user experience and reducing page load time by 30%",
      "Built comprehensive Reporting Dashboard enabling data-driven decision making for stakeholders",
    ],
  },
];
---

<section class="py-24 relative">
  <div class="container-custom">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Work Experience</h2>
        <p class="text-neutral-500 max-w-xl text-balance">
          My professional journey in building scalable web applications and leading frontend architectures.
        </p>
      </div>
      <a href="/experience" class="group flex items-center gap-2 text-sm font-medium text-foreground hover:text-neutral-500 transition-colors">
        View full resume
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <div class="relative pl-8 md:pl-0">
      <!-- Vertical line -->
      <div class="absolute left-[15px] md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-px bg-neutral-200 dark:bg-neutral-800"></div>

      <div class="space-y-12">
        {experiences.map((exp, index) => (
          <div class={`relative flex flex-col md:flex-row justify-between md:items-center gap-8 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
            
            <!-- Timeline dot -->
            <div class="absolute left-[-33px] md:left-1/2 md:-translate-x-1/2 w-8 h-8 rounded-full border-4 border-background bg-foreground shadow-sm z-10 flex items-center justify-center">
              <div class="w-2 h-2 rounded-full bg-background"></div>
            </div>

            <!-- Content Card -->
            <div class={`w-full md:w-[calc(50%-3rem)] ${index % 2 === 0 ? 'md:text-left' : 'md:text-right'}`}>
              <div class="group block p-6 rounded-3xl bg-neutral-50 dark:bg-neutral-900/50 border border-neutral-200/50 dark:border-neutral-800/50 hover:bg-white dark:hover:bg-neutral-900 hover:shadow-lg transition-all duration-300">
                <div class={`flex flex-col gap-2 mb-4 ${index % 2 === 0 ? 'md:items-start' : 'md:items-end'}`}>
                  <span class="inline-block px-3 py-1 rounded-full bg-neutral-200/50 dark:bg-neutral-800 text-xs font-semibold text-neutral-600 dark:text-neutral-300">
                    {exp.period}
                  </span>
                  <h3 class="text-xl font-bold tracking-tight text-foreground">{exp.company}</h3>
                  <div class="text-sm font-medium text-neutral-500">
                    {exp.position} • {exp.location}
                  </div>
                </div>
                
                <ul class={`flex flex-col gap-2 text-sm text-neutral-600 dark:text-neutral-400 ${index % 2 === 0 ? 'md:items-start text-left' : 'md:items-end md:text-right text-left'}`}>
                  {exp.achievements.map((achievement) => (
                    <li class="flex items-start gap-2 max-w-sm">
                      <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-neutral-300 dark:bg-neutral-700 shrink-0"></span>
                      <span>{achievement}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </div>
</section>
