---
import { Marquee } from "@/components/magicui/marquee";

const frontendSkills = [
  { name: "JavaScript", icon: "devicon-javascript-plain" },
  { name: "TypeScript", icon: "devicon-typescript-plain" },
  { name: "React", icon: "devicon-react-original" },
  { name: "Next.js", icon: "devicon-nextjs-plain" },
  { name: "Tailwind CSS", icon: "devicon-tailwindcss-original" },
  { name: "Svelte", icon: "devicon-svelte-plain" },
  { name: "Astro", icon: "devicon-astro-plain" },
  { name: "Ionic", icon: "devicon-ionic-original" },
  { name: "Capacitor", icon: "devicon-capacitor-plain" },
];

const backendSkills = [
  { name: "Node.js", icon: "devicon-nodejs-plain" },
  { name: "Express", icon: "devicon-express-original" },
  { name: "Nest.js", icon: "devicon-nestjs-plain" },
  { name: "Adonis.js", icon: "devicon-adonisjs-original" },
  { name: "Golang", icon: "devicon-go-original-wordmark" },
  { name: "PostgreSQL", icon: "devicon-postgresql-plain" },
  { name: "MongoDB", icon: "devicon-mongodb-plain" },
  { name: "Supabase", icon: "devicon-supabase-plain" },
  { name: "Docker", icon: "devicon-docker-plain" },
  { name: "Socket.io", icon: "devicon-socketio-original" },
];
---

<section class="py-24">
  <div class="container-custom">
    <div class="mb-12 flex flex-col items-center text-center">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Tech Stack</h2>
      <p class="text-neutral-500 max-w-2xl text-balance">
        I build applications using a wide variety of modern tools, prioritizing performance, developer experience, and scalability.
      </p>
    </div>

    <div class="relative flex w-full flex-col items-center justify-center overflow-hidden rounded-3xl bg-neutral-50/50 dark:bg-neutral-900/20 border border-neutral-200 dark:border-neutral-800 py-12 md:shadow-xl">
      <Marquee pauseOnHover class="[--duration:40s]">
        {
          frontendSkills.map((skill) => (
            <div class="flex items-center gap-3 px-6 py-3 mx-2 rounded-2xl bg-white dark:bg-neutral-900 border border-neutral-100 dark:border-neutral-800 shadow-sm hover:shadow-md transition-shadow">
              <i class={`${skill.icon} text-2xl colored`} />
              <span class="text-sm font-semibold">{skill.name}</span>
            </div>
          ))
        }
      </Marquee>

      <Marquee pauseOnHover reverse class="[--duration:45s] mt-6">
        {
          backendSkills.map((skill) => (
            <div class="flex items-center gap-3 px-6 py-3 mx-2 rounded-2xl bg-white dark:bg-neutral-900 border border-neutral-100 dark:border-neutral-800 shadow-sm hover:shadow-md transition-shadow">
              <i class={`${skill.icon} text-2xl colored`} />
              <span class="text-sm font-semibold">{skill.name}</span>
            </div>
          ))
        }
      </Marquee>

      <div class="pointer-events-none absolute inset-y-0 left-0 w-1/3 bg-gradient-to-r from-background dark:from-background to-transparent"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-1/3 bg-gradient-to-l from-background dark:from-background to-transparent"></div>
    </div>
  </div>
</section>
