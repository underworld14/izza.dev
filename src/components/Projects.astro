---
import { Image } from "astro:assets";
import { BorderBeam } from "./magicui/border-beam";

import luminapdfImg from "@/assets/projects/luminapdf.png";
import utarakanImg from "@/assets/projects/utarakan.png";
import carecryptoImg from "@/assets/projects/carecrypto.png";
import adhyaksamartImg from "@/assets/projects/adhyaksamart.png";

const projects = [
  {
    title: "Utarakan.id",
    description:
      "Anonymous social platform for sharing thoughts and experiences. Personal project attracting 600+ registered users with integrated payment processing.",
    tags: ["SvelteKit", "Supabase", "TWA", "Mayar Payment"],
    link: "https://utarakan.id",
    image: utarakanImg,
  },
  {
    title: "Carecrypto",
    description:
      "Membership-based crypto community for Seoul residents with integrated payment system and multiple membership tiers.",
    tags: ["Next.js", "Express.js", "MongoDB", "AWS Amplify", "AWS Elastic Beanstalk"],
    link: "https://carecrypto.com",
    image: carecryptoImg,
  },
  {
    title: "Adhyaksamart",
    description:
      "Digital voucher management system for Adhyaksamart members in Yogyakarta; manages 1,000+ vouchers monthly.",
    tags: ["SvelteKit", "SQLite"],
    link: "https://adhyaksamart.my.id",
    image: adhyaksamartImg,
  },
  {
    title: "Sharekorean",
    description:
      "Community platform with job portal for Koreans in the United States, offering specialized employment opportunities.",
    tags: ["Next.js", "Express.js", "MongoDB", "DigitalOcean"],
    link: "https://sharekorean.com",
    image: luminapdfImg,
  },
  {
    title: "Abqory Sharia",
    description:
      "Course and event management system for Sharia-based economic education, enabling structured learning and event registration.",
    tags: ["Next.js", "Strapi"],
    link: "https://abqorysharia.com",
    image: luminapdfImg,
  },
];
---

<section class="py-24">
  <div class="container-custom">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Featured Projects</h2>
        <p class="text-neutral-500 max-w-xl text-balance">
          A selection of projects I've built, ranging from community platforms to enterprise tools.
        </p>
      </div>
      <a href="/projects" class="group flex items-center gap-2 text-sm font-medium text-foreground hover:text-neutral-500 transition-colors">
        View all projects
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <div class="relative">
      <div class="grid gap-6 md:grid-cols-2 overflow-hidden max-h-[800px] md:max-h-[600px] pb-10">
        {
          projects.map((project) => (
            <div class="group relative flex flex-col overflow-hidden rounded-3xl border border-neutral-200/60 bg-white/50 dark:border-neutral-800/60 dark:bg-neutral-900/50 backdrop-blur-sm transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <div class="relative w-full aspect-[16/10] overflow-hidden bg-neutral-100 dark:bg-neutral-800">
                <Image
                  src={project.image}
                  alt={project.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>

              <div class="flex flex-col flex-1 p-6">
                <h3 class="text-xl font-bold tracking-tight mb-2 group-hover:text-primary transition-colors">{project.title}</h3>
                <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-6 flex-1">
                  {project.description}
                </p>

                <div class="flex flex-wrap gap-2 mt-auto">
                  {project.tags.map((tag) => (
                    <span class="inline-flex items-center rounded-full bg-neutral-100/80 px-3 py-1 text-xs font-semibold text-neutral-600 dark:bg-neutral-800/80 dark:text-neutral-300 backdrop-blur-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              <a
                href={project.link}
                class="absolute inset-0 z-10"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="sr-only">View {project.title}</span>
              </a>

              <BorderBeam client:idle duration={6} size={100} />
            </div>
          ))
        }
      </div>

      {/* Gradient overlay for fade out effect */}
      <div class="absolute z-20 bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-background via-background/80 to-transparent pointer-events-none"></div>

      <div class="absolute bottom-6 left-0 right-0 flex justify-center z-30">
        <a href="/projects" class="px-6 py-3 rounded-full bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-foreground font-medium hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors shadow-sm">
          Browse Portfolio
        </a>
      </div>
    </div>
  </div>
</section>
