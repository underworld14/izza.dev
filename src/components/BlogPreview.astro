---
import { getCollection } from "astro:content";

// Get all blog posts that aren't drafts
const allPosts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});

// Sort posts by date (newest first)
const posts = allPosts
  .sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
  )
  .slice(0, 4); // Only show the 4 most recent posts
---

<section class="py-24">
  <div class="container-custom">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Writing & Thoughts</h2>
        <p class="text-neutral-500 max-w-xl text-balance">
          I occasionally write about software engineering, frontend architecture, and my journey building products.
        </p>
      </div>
      <a href="/blog" class="group flex items-center gap-2 text-sm font-medium text-foreground hover:text-neutral-500 transition-colors">
        Read all articles
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    {posts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2">
        {posts.map((post) => (
          <article class="group relative overflow-hidden rounded-3xl border border-neutral-200/50 bg-neutral-50/50 dark:border-neutral-800/50 dark:bg-neutral-900/30 p-8 transition-all duration-300 hover:shadow-lg hover:bg-white dark:hover:bg-neutral-900 flex flex-col h-full">
            
            <div class="flex items-center gap-4 mb-4">
              <time
                datetime={post.data.date.toISOString()}
                class="text-xs font-semibold text-neutral-500 tracking-wider uppercase"
              >
                {new Date(post.data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
              {post.data.categories && post.data.categories.length > 0 && (
                <>
                  <span class="w-1 h-1 rounded-full bg-neutral-300 dark:bg-neutral-700"></span>
                  <span class="text-xs font-semibold text-primary/80">
                    {post.data.categories[0]}
                  </span>
                </>
              )}
            </div>
            
            <h3 class="text-2xl font-bold tracking-tight mb-3 group-hover:text-primary transition-colors line-clamp-2">
              {post.data.title}
            </h3>
            
            <p class="text-neutral-500 dark:text-neutral-400 mb-6 line-clamp-3 text-pretty">
              {post.data.description}
            </p>

            <div class="mt-auto flex items-center text-sm font-medium text-foreground group-hover:text-primary transition-colors pt-4 border-t border-neutral-200/50 dark:border-neutral-800/50">
              Read article
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 transition-transform group-hover:translate-x-1">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>

            <a href={`/blog/${post.slug}`} class="absolute inset-0 z-10">
              <span class="sr-only">Read {post.data.title}</span>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-neutral-50 dark:bg-neutral-900/30 rounded-3xl border border-neutral-200/50 dark:border-neutral-800/50">
        <p class="text-neutral-500">More articles coming soon.</p>
      </div>
    )}
  </div>
</section>
