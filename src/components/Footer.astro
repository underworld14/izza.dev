---
import Mail from "@lucide/astro/icons/mail";

const currentYear = new Date().getFullYear();

const links = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Experience", href: "/experience" },
  { name: "Projects", href: "/projects" },
  { name: "Blog", href: "/blog" }
];

const socials = [
  { name: "GitHub", href: "https://github.com/underworld14", icon: "devicon-github-original" },
  { name: "LinkedIn", href: "https://linkedin.com/in/izza-srv", icon: "devicon-linkedin-plain" },
  { name: "X (Twitter)", href: "https://x.com/underworld146", icon: "devicon-twitter-original" }
];
---

<footer class="border-t border-border mt-20 bg-background/50 backdrop-blur-sm">
  <div class="container-custom py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Brand & Description -->
      <div class="flex flex-col gap-4">
        <a href="/" class="text-xl font-bold tracking-tight">
          Izza<span class="text-neutral-500">.dev</span>
        </a>
        <p class="text-neutral-500 text-sm max-w-xs">
          Fullstack Engineer passionate about building seamless digital experiences and scalable web applications.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-col gap-4">
        <h3 class="font-semibold text-foreground">Navigation</h3>
        <ul class="flex flex-col gap-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-neutral-500 hover:text-foreground transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Socials -->
      <div class="flex flex-col gap-4">
        <h3 class="font-semibold text-foreground">Connect</h3>
        <div class="flex items-center gap-4">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-500 hover:text-foreground transition-colors"
              aria-label={social.name}
            >
              <i class={`text-xl ${social.icon}`}></i>
            </a>
          ))}
          <a
            href="mailto:yusril@izza.dev"
            class="text-neutral-500 hover:text-foreground transition-colors"
            aria-label="Email"
          >
            <Mail size={20} />
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-neutral-500">
        © {currentYear} Muhamad Yusril Izza Aulia. All rights reserved.
      </p>
      <p class="text-xs text-neutral-500">
        Built with 
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground hover:underline">Astro</a>, 
        <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground hover:underline">Tailwind v4</a> & 
        <a href="https://react.dev" target="_blank" rel="noopener noreferrer" class="font-medium text-foreground hover:underline">React</a>.
      </p>
    </div>
  </div>
</footer>
